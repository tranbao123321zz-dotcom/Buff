# ================= MAIN =================
if __name__ == "__main__":
    import sys
    import json
    
    if len(sys.argv) < 2:
        print("Usage: python buff.py <platform> [target_url]")
        print("Platform: facebook, instagram, tiktok, twitter")
        print("Example: python buff.py facebook https://facebook.com/yourpost")
        sys.exit(1)
    
    platform = sys.argv[1].lower()
    target = sys.argv[2] if len(sys.argv) > 2 else Config.TARGET_URLS.get(platform, "")
    
    if not target:
        print("[-] Vui lòng cung cấp URL target hoặc sửa trong Config")
        sys.exit(1)
    
    bot = SocialBuffBot(platform, target)
    bot.run()
